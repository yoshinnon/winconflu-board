@* WinConflu.NET — UserSearchPopover.razor
   Graph API でADユーザーをインクリメンタル検索するコンポーネント。
   チケット担当者選択など、AssigneeSid 入力欄の代替として使用する。 *@

@inject IUserProfileService ProfileSvc
@inject IPresenceService PresenceSvc

<div style="position:relative">
    <MudTextField @bind-Value="_query"
                  Immediate="true"
                  DebounceInterval="300"
                  OnDebounceIntervalElapsed="SearchUsers"
                  Label="@Label"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Placeholder="名前またはメールで検索..."
                  @onfocus="() => _open = _results.Any()"
                  @onblur="DelayClose" />

    @if (_open && _results.Any())
    {
        <MudPaper Elevation="4"
                  Style="position:absolute;top:100%;left:0;right:0;z-index:2000;max-height:280px;overflow-y:auto">
            @foreach (var user in _results)
            {
                <div class="d-flex align-center gap-2 pa-2 cursor-pointer"
                     style="border-bottom:0.5px solid var(--mud-palette-divider)"
                     @onmousedown="() => SelectUser(user)">
                    @* 顔写真またはイニシャルアバター *@
                    @if (_photos.TryGetValue(user.Id, out var photoSrc) && photoSrc != null)
                    {
                        <MudAvatar Size="Size.Small">
                            <MudImage Src="@photoSrc" />
                        </MudAvatar>
                    }
                    else
                    {
                        <MudAvatar Size="Size.Small" Color="Color.Primary">
                            @user.DisplayName.FirstOrDefault()
                        </MudAvatar>
                    }
                    <div>
                        <div class="d-flex align-center gap-1">
                            <MudText Typo="Typo.body2" Style="font-weight:500">@user.DisplayName</MudText>
                            @* プレゼンスドット *@
                            @if (_presences.TryGetValue(user.Id, out var pres))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Circle"
                                         Size="Size.Small"
                                         Color="@PresenceColor(pres.Availability)"
                                         Style="font-size:8px" />
                            }
                        </div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @user.Department  @(string.IsNullOrEmpty(user.Department) ? "" : " · ") @user.Mail
                        </MudText>
                    </div>
                </div>
            }
        </MudPaper>
    }
</div>

@code {
    [Parameter] public string  Label    { get; set; } = "担当者";
    [Parameter] public string? Value    { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    private string                     _query    = string.Empty;
    private bool                       _open     = false;
    private List<GraphUserProfile>     _results  = [];
    private Dictionary<string, string?> _photos  = [];
    private Dictionary<string, UserPresence> _presences = [];

    protected override void OnParametersSet()
    {
        // Value (UPN) が外部からセットされていたら表示名として反映
        if (!string.IsNullOrEmpty(Value) && string.IsNullOrEmpty(_query))
            _query = Value;
    }

    private async Task SearchUsers()
    {
        if (_query.Length < 2) { _results = []; _open = false; return; }

        _results  = await ProfileSvc.SearchUsersAsync(_query, top: 8);
        _open     = _results.Any();

        // 顔写真とプレゼンスを非同期で取得（表示を止めない）
        _ = LoadAvatarsAsync();
        _ = LoadPresencesAsync();
    }

    private async Task LoadAvatarsAsync()
    {
        foreach (var user in _results)
        {
            var bytes = await ProfileSvc.GetPhotoAsync(user.Id);
            if (bytes != null)
            {
                var base64 = Convert.ToBase64String(bytes);
                _photos[user.Id] = $"data:image/jpeg;base64,{base64}";
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task LoadPresencesAsync()
    {
        var presences = await PresenceSvc.GetBulkPresenceAsync(_results.Select(u => u.Id));
        _presences = presences.ToDictionary(p => p.UserId);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectUser(GraphUserProfile user)
    {
        _query = user.DisplayName;
        _open  = false;
        await ValueChanged.InvokeAsync(user.UserPrincipalName ?? user.Id);
    }

    private async Task DelayClose()
    {
        await Task.Delay(150);
        _open = false;
    }

    private static Color PresenceColor(string availability) => availability switch
    {
        "Available"    => Color.Success,
        "Busy"         => Color.Error,
        "DoNotDisturb" => Color.Error,
        "Away"         => Color.Warning,
        _              => Color.Default
    };
}
